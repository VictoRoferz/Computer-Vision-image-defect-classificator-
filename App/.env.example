# ============================================================
# PCB Defect Classification System - Environment Configuration
# ============================================================
# Copy this file to .env and adjust values as needed:
#   cp .env.example .env

# ---- General ----
LOG_LEVEL=INFO

# ---- Camera Service (Server 1) ----
USE_CAMERA=false              # Set to true to use laptop webcam
CAMERA_INDEX=0                # 0 = default camera
CAMERA_WIDTH=1920
CAMERA_HEIGHT=1080
UPLOAD_TIMEOUT=30
UPLOAD_RETRIES=3
CLEANUP_AFTER_UPLOAD=true

# ---- GPIO Button (Raspberry Pi 3 only) ----
BUTTON_MODE=label               # "label" (capture→Label Studio) or "inference" (capture→predict)
BUTTON_GPIO_PIN=23              # BCM pin number for the capture button

# ---- Label Studio ----
LABELSTUDIO_API_KEY=           # Required: get from Label Studio UI > Account > Access Token
LABELSTUDIO_PROJECT_ID=        # Leave empty to auto-create
LABELSTUDIO_PROJECT_NAME=PCB Defect Classification
LABELSTUDIO_AUTO_CREATE_PROJECT=true
LABELSTUDIO_ENABLE_WEBHOOKS=true
LABELSTUDIO_USERNAME=admin@example.com
LABELSTUDIO_PASSWORD=admin123

# ---- Storage (Server 2) ----
USE_CONTENT_ADDRESSING=true
MAX_UPLOAD_SIZE_MB=50

# ---- ML Inference (Server 3) ----
MODEL_PATH=models/yolov8n.pt   # Path inside container
CONFIDENCE_THRESHOLD=0.25      # Detection confidence threshold (0.0-1.0)
